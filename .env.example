# ── Environment variables ───────────────────────────────────
# Copy to .env.local and fill in values. Never commit real secrets.

# ── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# ── Supabase (backend) ──────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Pipeline selection ─────────────────────────────────────
# fm      = Foundation-model pipeline (OSM + NIM VLM) — default, zero training
# runpod  = Trained SegFormer on RunPod Serverless (requires training first)
# local   = Load models locally (requires GPU + TorchScript/MLflow)
PIPELINE=fm

# ── Active region / market ────────────────────────────────
# TH = Thailand (default — THB pricing, Thai geocoder biasing, monsoon climate prompt)
# US = United States (USD pricing, generic prompt)
REGION=TH

# ── NVIDIA NIM (vision-language model for corrosion assessment) ──
# Get free API key at https://build.nvidia.com → 1,000 credits on signup
NVIDIA_API_KEY=your-nvidia-api-key
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.2-90b-vision-instruct

# ── SAM 2 backend for roof segmentation (optional — OSM used first) ──
# If SAM_RUNPOD_ENDPOINT_ID is set → self-hosted on RunPod
# If REPLICATE_API_TOKEN is set → hosted on Replicate
# Otherwise → local segment-geospatial (requires pip install)
SAM_RUNPOD_ENDPOINT_ID=
REPLICATE_API_TOKEN=

# ── RunPod API — Serverless GPU for trained models (optional) ──
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_ENDPOINT_ID=your-inference-endpoint-id
RUNPOD_TRAINING_ENDPOINT_ID=your-training-endpoint-id
# Docker registry for RunPod worker images
DOCKER_REGISTRY=docker.io/yourusername

# Maxar/Nearmap tile APIs
MAXAR_API_KEY=your-maxar-api-key
NEARMAP_API_KEY=your-nearmap-api-key

# S3 (model artifacts + tile cache)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=roof-corrosion-mlops
AWS_REGION=us-east-1

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Redis (job queue)
REDIS_URL=redis://localhost:6379/0

# Label Studio
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=your-label-studio-key
