# ── Environment variables ───────────────────────────────────
# Copy to .env.local and fill in values. Never commit real secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RunPod API
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_ENDPOINT_ID=your-endpoint-id

# Maxar/Nearmap tile APIs
MAXAR_API_KEY=your-maxar-api-key
NEARMAP_API_KEY=your-nearmap-api-key

# S3 (model artifacts + tile cache)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=roof-corrosion-mlops
AWS_REGION=us-east-1

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Redis (job queue)
REDIS_URL=redis://localhost:6379/0

# Label Studio
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=your-label-studio-key
